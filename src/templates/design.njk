<dialog
  id="design"
  class="modal"
  aria-labelledby="design__title"
  data-modal
  data-sub-event="design: open-request"
  data-pub-event="design: close"
>
  <header class="modal__header modal__header--design">
    <h2 class="modal__title">Дизайн</h2>
    <p class="modal__description">Айдентика и полиграфия</p>
    <button
      class="close-button"
      type="button"
      aria-label="Закрыть окно"
      data-event-button
      data-pub-event="design: open-request"
    >
      <svg class="close-button__icon" aria-hidden="true">
        <use href="#icon-close"></use>
      </svg>
    </button>
  </header>
  <div class="modal__wrapper">
    <div class="modal__project-wrapper">
      <picture class="modal__photo-wrapper">
        <source srcset="/src/assets/images/design/coffee-drunker.webp" type="image/webp" />
        <img
          class="modal__photo"
          src="/src/assets/images/design/coffee-drunker.png"
          alt=""
          decoding="async"
          loading="lazy"
        />
      </picture>
      <div class="modal__info">
        <h3 class="modal__subtitle modal__subtitle--design">Логотип кофейни Coffee Drunker</h3>
        <a
          href="https://www.figma.com/design/QAftouf8eHwK7nxagNwnto/coffee-drunker?node-id=154-1012&t=VsWT8hJQ9LIUTvRL-1"
          class="project-link"
          aria-label="перейти в Figma проекта"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="project-icon" aria-hidden="true">
            <use href="#icon-figma"></use>
          </svg>
        </a>
      </div>
    </div>

    <div class="modal__project-wrapper">
      <picture class="modal__photo-wrapper">
        <source srcset="/src/assets/images/design/aline.webp" type="image/webp" />
        <img
          class="modal__photo"
          src="/src/assets/images/design/aline.png"
          alt=""
          decoding="async"
          loading="lazy"
        />
      </picture>
      <div class="modal__info">
        <h3 class="modal__subtitle modal__subtitle--design">Логотип архитектурного бюро Aline</h3>
        <a
          href="https://www.figma.com/design/Epo76L6vYldDOt2pxJeLnq/%D0%BB%D0%BE%D0%B3%D0%BE%D1%82%D0%B8%D0%BF--%D0%B0%D1%80%D1%85%D0%B8%D1%82%D0%B5%D0%BA%D1%82%D1%83%D1%80%D0%BD%D0%BE%D0%B5-%D0%B1%D1%8E%D1%80%D0%BE-aline?node-id=149-2&t=VsWT8hJQ9LIUTvRL-1"
          class="project-link"
          aria-label="перейти в Figma проекта"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="project-icon" aria-hidden="true">
            <use href="#icon-figma"></use>
          </svg>
        </a>
      </div>
    </div>

    <div class="modal__project-wrapper">
      <picture class="modal__photo-wrapper">
        <source srcset="/src/assets/images/design/lofi-house.webp" type="image/webp" />
        <img
          class="modal__photo"
          src="/src/assets/images/design/lofi-house.png"
          alt=""
          decoding="async"
          loading="lazy"
        />
      </picture>
      <div class="modal__info">
        <h3 class="modal__subtitle modal__subtitle--design">Плакат для муз. события Lo-Fi House</h3>
        <a
          href="https://www.figma.com/design/4Lp0eeJdZodKxwofgkhJzT/%D0%9F%D0%BB%D0%B0%D0%BA%D0%B0%D1%82-Lo-FI-House?node-id=87-2&t=VsWT8hJQ9LIUTvRL-1"
          class="project-link"
          aria-label="перейти в Figma проекта"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="project-icon" aria-hidden="true">
            <use href="#icon-figma"></use>
          </svg>
        </a>
      </div>
    </div>

    <div class="modal__project-wrapper">
      <picture class="modal__photo-wrapper">
        <source srcset="/src/assets/images/design/lighthouse.webp" type="image/webp" />
        <img
          class="modal__photo"
          src="/src/assets/images/design/lighthouse.png"
          alt=""
          decoding="async"
          loading="lazy"
        />
      </picture>
      <div class="modal__info">
        <h3 class="modal__subtitle modal__subtitle--design">Лифлет тура по маякам Камчатки</h3>
        <a
          href="https://www.figma.com/design/rh9VoB9WqtM8OhXI4oOW8i/%D0%9B%D0%B8%D1%84%D0%BB%D0%B5%D1%82-%D0%A2%D1%83%D1%80-%D0%BF%D0%BE-%D0%BC%D0%B0%D1%8F%D0%BA%D0%B0%D0%BC?node-id=132-2&t=VsWT8hJQ9LIUTvRL-1"
          class="project-link"
          aria-label="перейти в Figma проекта"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="project-icon" aria-hidden="true">
            <use href="#icon-figma"></use>
          </svg>
        </a>
      </div>
    </div>
  </div>
</dialog>
